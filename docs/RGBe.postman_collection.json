    {
      "name": "initial-login-page",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Extract cookies from Set-Cookie headers and store them as environment variables",
              "",
              "// Get all Set-Cookie headers from the response",
              "const setCookieHeaders = pm.response.headers.filter(header => header.key.toLowerCase() === 'set-cookie');",
              "",
              "// Object to store all cookies",
              "const allCookies = {};",
              "",
              "// Parse each Set-Cookie header",
              "setCookieHeaders.forEach(header => {",
              "    // Get the cookie string (first part before any semicolon contains name=value)",
              "    const cookieString = header.value.split(';')[0].trim();",
              "    ",
              "    // Split into name and value",
              "    const separatorIndex = cookieString.indexOf('=');",
              "    if (separatorIndex > 0) {",
              "        const cookieName = cookieString.substring(0, separatorIndex).trim();",
              "        const cookieValue = cookieString.substring(separatorIndex + 1).trim();",
              "        ",
              "        // Store each cookie as an environment variable",
              "        pm.environment.set(cookieName, cookieValue);",
              "        ",
              "        // Add to allCookies object",
              "        allCookies[cookieName] = cookieValue;",
              "    }",
              "});",
              "",
              "// Store all cookies as a JSON string in 'cookies_all' environment variable",
              "pm.environment.set('cookies_all', JSON.stringify(allCookies));",
              "",
              "// Log the number of cookies found",
              "console.log('Cookies found: ' + Object.keys(allCookies).length);",
              "",
              "// Assertions for cookies",
              "pm.test(\"Cookies extracted and stored (if present in response)\", function() {",
              "    const cookieCount = Object.keys(allCookies).length;",
              "    const headerCount = setCookieHeaders.length;",
              "    ",
              "    if (headerCount > 0) {",
              "        pm.expect(cookieCount).to.be.at.least(1, 'Set-Cookie headers found but no cookies were parsed');",
              "    } else {",
              "        pm.expect(cookieCount).to.equal(0, 'No Set-Cookie headers in response');",
              "    }",
              "});",
              "",
              "pm.test(\"Environment variable 'cookies_all' is present\", function() {",
              "    pm.expect(pm.environment.get('cookies_all')).to.not.be.undefined;",
              "});",
              "",
              "// Extract CSRF token from HTML response body",
              "const responseBody = pm.response.text();",
              "",
              "// Use regex to find the hidden input field with name=\"csrf_token\"",
              "const csrfTokenMatch = responseBody.match(/<input[^>]*name=[\"']csrf_token[\"'][^>]*value=[\"']([^\"']+)[\"'][^>]*>/i) ||",
              "                       responseBody.match(/<input[^>]*value=[\"']([^\"']+)[\"'][^>]*name=[\"']csrf_token[\"'][^>]*>/i);",
              "",
              "if (csrfTokenMatch && csrfTokenMatch[1]) {",
              "    pm.environment.set('csrf_token', csrfTokenMatch[1]);",
              "    console.log('CSRF token extracted and stored');",
              "}",
              "",
              "// Test for CSRF token extraction",
              "pm.test(\"Environment variable 'csrf_token' is set to a non-empty string\", function() {",
              "    const storedCsrfToken = pm.environment.get('csrf_token');",
              "    pm.expect(storedCsrfToken).to.be.a('string');",
              "    pm.expect(storedCsrfToken.length).to.be.greaterThan(0, 'csrf_token should not be empty');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{host}}/",
