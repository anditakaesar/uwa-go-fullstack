    {
      "name": "initial-login-submit",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Read cookies_all from environment variable",
              "const cookiesAllRaw = pm.environment.get('cookies_all');",
              "",
              "let cookieHeaderValue = '';",
              "",
              "if (cookiesAllRaw) {",
              "    try {",
              "        // Parse the JSON string into an object { name: value }",
              "        const cookiesObj = JSON.parse(cookiesAllRaw);",
              "        ",
              "        // Build the cookie string: name1=value1; name2=value2",
              "        const envCookieParts = [];",
              "        for (const [name, value] of Object.entries(cookiesObj)) {",
              "            envCookieParts.push(`${name}=${value}`);",
              "        }",
              "        const envCookieString = envCookieParts.join('; ');",
              "        ",
              "        // Check if there's an existing Cookie header",
              "        const existingCookieHeader = pm.request.headers.get('Cookie');",
              "        ",
              "        if (existingCookieHeader) {",
              "            // Parse existing cookies into an object",
              "            const existingCookiesObj = {};",
              "            existingCookieHeader.split(';').forEach(part => {",
              "                const [key, ...valueParts] = part.trim().split('=');",
              "                if (key) {",
              "                    existingCookiesObj[key.trim()] = valueParts.join('=');",
              "                }",
              "            });",
              "            ",
              "            // Merge: env cookies take precedence over existing ones",
              "            const mergedCookiesObj = { ...existingCookiesObj, ...cookiesObj };",
              "            ",
              "            // Build merged cookie string",
              "            const mergedCookieParts = [];",
              "            for (const [name, value] of Object.entries(mergedCookiesObj)) {",
              "                mergedCookieParts.push(`${name}=${value}`);",
              "            }",
              "            cookieHeaderValue = mergedCookieParts.join('; ');",
              "        } else {",
              "            cookieHeaderValue = envCookieString;",
              "        }",
              "        ",
              "        // Set the Cookie header on the request",
              "        pm.request.headers.upsert({",
              "            key: 'Cookie',",
              "            value: cookieHeaderValue",
              "        });",
              "        ",
              "        console.log('Cookie header set from cookies_all:', cookieHeaderValue);",
              "        ",
              "        // Test to assert Cookie header is set when cookies_all has entries",
              "        if (Object.keys(cookiesObj).length > 0) {",
              "            pm.test('Cookie header is set from environment cookies', function () {",
              "                const cookieHeader = pm.request.headers.get('Cookie');",
              "                pm.expect(cookieHeader).to.be.a('string');",
              "                pm.expect(cookieHeader.length).to.be.greaterThan(0);",
              "                console.log('Assertion passed: Cookie header is set with value:', cookieHeader);",
              "            });",
              "        }",
              "        ",
              "    } catch (e) {",
              "        console.error('Failed to parse cookies_all:', e.message);",
              "    }",
              "} else {",
              "    console.log('No cookies_all environment variable found. Skipping Cookie header construction.');",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Parse the JSON response body",
              "const json = pm.response.json();",
              "",
              "// If status is 200 and token is present, set the environment variable",
              "if (pm.response.code === 200 && json.data && json.data.token) {",
              "    pm.environment.set('token', json.data.token);",
              "}",
              "",
              "// Test: Assert status code is 200",
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test: Assert that data.token exists",
              "pm.test('Response contains data.token', function () {",
              "    pm.expect(json.data).to.have.property('token');",
              "    pm.expect(json.data.token).to.be.a('string').and.not.be.empty;",
              "});",
              "",
              "// Test: Assert that environment variable 'token' has been set and matches response value",
              "pm.test('Environment variable token is set and matches response', function () {",
              "    const envToken = pm.environment.get('token');",
              "    pm.expect(envToken).to.exist;",
              "    pm.expect(envToken).to.eql(json.data.token);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
